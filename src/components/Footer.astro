---
import { CALCULATORS, LEDGERS } from '~/lib/catalogue'
/*
 * Footer — closing the books.
 *
 * Three blocks separated by tan rules:
 *   Left   — identity + SEBI/IRDAI/RBI disclaimer in oxblood (--debit)
 *   Centre — leader-dotted index of every calculator on the site
 *            (the whole footer IS the sitemap)
 *   Right  — family-sites list with same leader-dotted treatment
 *
 * Closes with a full-width DOUBLE rule (the same border-double convention
 * used for totals rows in tables — closes the books) and a single mono
 * line: `end of folio · MIT · CC BY 4.0 · no inputs leave your device`.
 *
 * Build-time deploy metadata read from PUBLIC_DEPLOY_TIME / PUBLIC_GIT_SHA;
 * falls back to current ISO time + 'dev'.
 */
import { FAMILY_SITES } from '~/lib/family'

const deployTime =
  import.meta.env.PUBLIC_DEPLOY_TIME ?? new Date().toISOString().slice(0, 16).replace('T', ' ')
const gitSha = import.meta.env.PUBLIC_GIT_SHA ?? 'dev'

const familySites = FAMILY_SITES.filter((s) => s.slug !== 'finance')
---

<footer class="ft">
  <hr class="hairline" />
  <div class="spine ft-grid">
    {/* ── Left: identity + regulator disclaimer ── */}
    <section class="ft-col ft-col-id">
      <p class="ft-mark mono">oriz · finance</p>
      <p class="ft-tag">
        Calculators that show the math. SIP, EMI, FIRE, FD, RD, PPF, NPS,
        HRA, TDS, take-home. No popups. No advisor CTA. Inputs never leave
        your device.
      </p>
      <p class="ft-disc">
        <strong>Not registered with SEBI, IRDAI, or RBI.</strong> Calculators
        are mathematical tools — outputs are deterministic functions of your
        inputs, not investment, tax, or insurance advice. Past performance
        is not indicative of future returns. Mutual fund investments are
        subject to market risks; read all scheme-related documents carefully.
        Consult a SEBI-registered investment advisor before acting.
      </p>
      <p class="ft-disc-link">
        <a href="/legal/disclaimer/">Read the full disclaimer →</a>
      </p>
    </section>

    {/* ── Centre: leader-dotted index of every calculator ── */}
    <section class="ft-col ft-col-index" aria-label="Calculator index">
      <h2 class="ft-h mono">Catalogue</h2>
      {LEDGERS.map((l) => (
        <div class="ft-ledger">
          <h3 class="ft-ledger-h mono">{l.label}</h3>
          <ul class="ft-list">
            {CALCULATORS.filter((c) => c.ledger === l.key).map((c) => (
              <li>
                <a class="toc-row" href={c.live ? `/calculators/${c.slug}/` : '/#catalogue'}>
                  <span class="toc-name">{c.name}</span>
                  <span class="toc-value mono">{c.live ? 'live' : 'soon'}</span>
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </section>

    {/* ── Right: family-sites list, same leader-dotted treatment ── */}
    <section class="ft-col ft-col-fam" aria-label="oriz family">
      <h2 class="ft-h mono">Family</h2>
      <ul class="ft-list">
        {familySites.map((s) => (
          <li>
            <a class="toc-row" href={s.url}>
              <span class="toc-name">{s.name}</span>
              <span class="toc-value mono">{s.url.replace('https://', '')}</span>
            </a>
          </li>
        ))}
      </ul>

      <h2 class="ft-h mono ft-h-2">Meta</h2>
      <ul class="ft-list">
        <li>
          <a class="toc-row" href="/about/">
            <span class="toc-name">About</span>
            <span class="toc-value mono">/about/</span>
          </a>
        </li>
        <li>
          <a class="toc-row" href="/contact/">
            <span class="toc-name">Contact</span>
            <span class="toc-value mono">/contact/</span>
          </a>
        </li>
        <li>
          <a class="toc-row" href="/account/">
            <span class="toc-name">Account</span>
            <span class="toc-value mono">/account/</span>
          </a>
        </li>
        <li>
          <a class="toc-row" href="/legal/">
            <span class="toc-name">Legal</span>
            <span class="toc-value mono">/legal/</span>
          </a>
        </li>
      </ul>
    </section>
  </div>

  {/* ── Closing strip: DOUBLE rule across full width + single mono line ── */}
  <div class="ft-close">
    <div class="ft-double" aria-hidden="true"></div>
    <div class="spine ft-end mono">
      end of folio &middot; MIT &middot; CC BY 4.0 &middot; no inputs leave your device
    </div>
    <div class="spine ft-deploy mono">
      <time datetime={deployTime}>{deployTime}</time> &middot; commit <code>{gitSha}</code>
    </div>
  </div>
</footer>

<style>
  .ft {
    margin-top: 6rem;
    background: color-mix(in oklab, var(--paper) 85%, transparent);
  }
  .ft-grid {
    display: grid;
    grid-template-columns: 1.1fr 1.4fr 1fr;
    gap: 0;
    padding-block: 2.5rem;
  }
  .ft-col {
    padding-inline: 1.5rem;
  }
  .ft-col:first-child {
    padding-left: 0;
    border-right: 1px solid var(--rule);
  }
  .ft-col-index {
    border-right: 1px solid var(--rule);
  }
  .ft-col:last-child {
    padding-right: 0;
  }

  .ft-mark {
    font-family: var(--font-mono);
    font-size: 13px;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--ink);
    font-weight: 500;
    margin: 0 0 1rem;
    font-feature-settings: 'tnum' 1, 'zero' 1, 'calt' 0;
  }
  .ft-tag {
    color: var(--ink);
    font-size: 14px;
    line-height: 1.55;
    margin: 0 0 1.25rem;
    max-width: 38ch;
  }
  .ft-disc {
    color: var(--debit);
    font-size: 13px;
    line-height: 1.55;
    margin: 0 0 0.5rem;
    max-width: 42ch;
  }
  .ft-disc strong {
    font-weight: 600;
  }
  .ft-disc-link {
    margin: 0;
    font-size: 13px;
  }
  .ft-disc-link a {
    color: var(--ink);
    text-decoration: underline;
    text-decoration-color: var(--rule);
    text-underline-offset: 3px;
  }
  .ft-disc-link a:hover {
    color: var(--accent);
    text-decoration-color: var(--accent);
  }

  .ft-h {
    font-family: var(--font-mono);
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: var(--ink-mute);
    font-weight: 500;
    margin: 0 0 1rem;
    font-feature-settings: 'tnum' 1, 'zero' 1, 'calt' 0;
  }
  .ft-h-2 {
    margin-top: 1.5rem;
  }
  .ft-ledger {
    margin-bottom: 1rem;
  }
  .ft-ledger-h {
    font-family: var(--font-mono);
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--ink-mute);
    font-weight: 500;
    margin: 0 0 0.375rem;
    font-feature-settings: 'tnum' 1, 'zero' 1, 'calt' 0;
  }
  .ft-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
  }
  .ft-list .toc-row {
    font-size: 13px;
    line-height: 1.5;
  }
  .ft-list .toc-row .toc-value {
    font-size: 11px;
  }

  .ft-close {
    margin-top: 0;
  }
  .ft-double {
    width: 100%;
    height: 6px;
    border-top: 1px solid var(--ink);
    border-bottom: 1px solid var(--ink);
    background: transparent;
  }
  .ft-end {
    padding-block: 0.875rem 0.25rem;
    text-align: center;
    font-size: 12px;
    text-transform: lowercase;
    letter-spacing: 0.1em;
    color: var(--ink-mute);
    font-feature-settings: 'tnum' 1, 'zero' 1, 'calt' 0;
  }
  .ft-deploy {
    padding-block: 0 1.25rem;
    text-align: center;
    font-size: 11px;
    color: var(--ink-mute);
    font-feature-settings: 'tnum' 1, 'zero' 1, 'calt' 0;
  }
  .ft-deploy code {
    color: var(--ink);
  }

  @media (max-width: 900px) {
    .ft-grid {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }
    .ft-col {
      padding-inline: 0;
      border-right: 0 !important;
      border-bottom: 1px solid var(--rule);
      padding-bottom: 2rem;
    }
    .ft-col:last-child {
      border-bottom: 0;
      padding-bottom: 0;
    }
  }
</style>
