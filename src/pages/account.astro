---
import AccountPanel from '~/components/AccountPanel.tsx'
/*
 * /account — sign-in / sign-out via Firebase Auth.
 * The AccountPanel island uses `data-oriz-account-*` selector hooks; styling
 * lives in src/styles/oriz-ui-overrides.css.
 */
import BaseLayout from '~/layouts/BaseLayout.astro'
import { SITE_CONFIG } from '~/lib/siteConfig'
import '~/lib/firebase'
---

<BaseLayout
  title={`Account — ${SITE_CONFIG.name}`}
  description={`Sign in to ${SITE_CONFIG.name}. One account works across every oriz site.`}
  noindex={true}
>
  <header class="prose-spine page-head">
    <p class="eyebrow"><a href="/">finance</a> / account</p>
    <h1>Account</h1>
    <p class="lede">
      One sign-in works across every oriz site. Saved scenarios and
      bookmarks follow you.
    </p>
  </header>

  <section class="prose-spine">
    <AccountPanel client:load siteName={SITE_CONFIG.name} />
  </section>
</BaseLayout>
