---
import ContactForm from '~/components/ContactForm.tsx'
import BaseLayout from '~/layouts/BaseLayout.astro'
import { SITE_CONFIG } from '~/lib/siteConfig'

const web3formsKey = import.meta.env.PUBLIC_WEB3FORMS_KEY ?? ''
---

<BaseLayout
  title={`Contact — ${SITE_CONFIG.name}`}
  description={`Get in touch about ${SITE_CONFIG.name} on oriz.`}
>
  <header class="prose-spine page-head">
    <p class="eyebrow"><a href="/">finance</a> / contact</p>
    <h1>Contact</h1>
  </header>

  <section class="prose-spine prose">
    <p class="lede">
      Spotted a calculation that looks off? A formula you want documented?
      An EMI scenario this site doesn't yet handle? Tell me — calculator
      correctness is the whole point of {SITE_CONFIG.name}.
    </p>
    <p>
      Email is fastest:
      <a href="mailto:whyiswhen@gmail.com"><strong>whyiswhen@gmail.com</strong></a>.
      Otherwise the form below posts to Web3Forms which forwards to my inbox.
      No data is stored on this site.
    </p>

    <ContactForm
      client:idle
      web3formsKey={web3formsKey}
      fromName={`${SITE_CONFIG.name} contact form`}
    />

    <p class="meta">
      For privacy questions or DMCA notices, see the
      <a href="/legal/grievance/">grievance officer</a> page (mandatory under
      IT Rules 2021).
    </p>
  </section>
</BaseLayout>
