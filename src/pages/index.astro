---
import InlineSIPCalculator from '~/components/InlineSIPCalculator.tsx'
/*
 * Home — folio strip + headline + inline live SIP calculator + leader-dotted
 * catalogue of all 28 calculators across 4 ledgers.
 *
 * The page IS a ledger sheet. The grid is the chrome; the dotted leaders are
 * the index; the double rule is the sum.
 */
import BaseLayout from '~/layouts/BaseLayout.astro'
import { CALCULATORS, LEDGERS } from '~/lib/catalogue'
import { SITE_CONFIG } from '~/lib/siteConfig'

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: `${SITE_CONFIG.name} — oriz`,
  url: SITE_CONFIG.origin,
  description: SITE_CONFIG.description,
  publisher: { '@type': 'Person', name: 'Chirag Singhal', url: 'https://oriz.in' },
}
---

<BaseLayout jsonLd={jsonLd}>
  {/* ── Hero — Fraunces 64px headline + Source Sans lede ── */}
  <section class="spine hero" aria-label="Folio of calculators">
    <h1 class="hero-h">Calculators that show the math.</h1>
    <p class="hero-sub">
      A folio of <span class="num">28</span> calculators for Indian money — SIP, EMI,
      FIRE, FD, RD, PPF, NPS, HRA, TDS, take-home. No popups. No advisor CTA. Inputs
      never leave your device.
    </p>
  </section>

  {/* ── Inline live SIP calculator ── */}
  <section class="spine isip-section" aria-label="Live SIP calculator">
    <h2 class="section-h mono">SIP — live</h2>
    <p class="section-lede">
      A taste. Type a monthly amount, expected return, and tenure; the corpus
      updates as you type. The full ledger sits one click away.
    </p>
    <InlineSIPCalculator client:idle />
  </section>

  {/* ── Catalogue — leader-dotted TOC of every calculator ── */}
  <section id="catalogue" class="spine cat" aria-label="Catalogue">
    <h2 class="section-h mono">Catalogue</h2>
    <p class="section-lede">
      <span class="num">{CALCULATORS.length}</span> calculators across{' '}
      <span class="num">{LEDGERS.length}</span> ledgers. The two-letter code on
      the right of each row is `live` when the calculator is wired up;
      otherwise `soon`.
    </p>

    {LEDGERS.map((ledger) => (
      <div class="cat-ledger">
        <h3 class="cat-ledger-h">
          <span class="cat-ledger-num mono">
            {LEDGERS.findIndex((l) => l.key === ledger.key) + 1}.
          </span>
          {ledger.label}
        </h3>
        <ul class="cat-list">
          {CALCULATORS.filter((c) => c.ledger === ledger.key).map((c) => (
            <li>
              <a class="toc-row cat-row" href={c.live ? `/calculators/${c.slug}/` : `/calculators/${c.slug}/`}>
                <span class="toc-name cat-name">{c.name}</span>
                <span class="toc-value cat-status mono">{c.live ? 'live' : 'soon'}</span>
              </a>
              <p class="cat-brief">{c.brief}</p>
            </li>
          ))}
        </ul>
      </div>
    ))}
  </section>

  {/* ── How this stays free ── */}
  <section class="spine note" aria-label="How this stays free">
    <h2 class="section-h mono">How this stays free</h2>
    <div class="note-prose">
      <p>
        Every calculator runs in your browser. The math, the formula, the
        year-by-year breakdown — all client-side. Inputs never leave your
        device. Sign-in is optional and only unlocks the ability to save
        scenarios across the oriz family of sites.
      </p>
      <p>
        Display ads on a few pages cover the domain renewal. Nothing is
        gated. <a href="/legal/disclaimer/">Read the SEBI disclaimer →</a>
      </p>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    padding-block: clamp(3rem, 8vw, 4.5rem) clamp(1.5rem, 4vw, 2.25rem);
    border-bottom: 1px solid var(--rule);
  }
  .hero-h {
    font-family: var(--font-display);
    font-weight: 500;
    font-variation-settings: 'opsz' 144, 'SOFT' 100;
    /* H1 only at 64px per the brief — small footprint, big presence. */
    font-size: clamp(2.25rem, 6vw, 4rem);
    line-height: 1.05;
    letter-spacing: -0.01em;
    color: var(--ink);
    margin: 0 0 1rem;
    max-width: 18ch;
  }
  .hero-sub {
    font-size: 1.125rem;
    line-height: 1.55;
    color: var(--ink);
    margin: 0;
    max-width: 60ch;
  }

  .isip-section {
    padding-block: clamp(2rem, 5vw, 3rem);
    border-bottom: 1px solid var(--rule);
  }
  .section-h {
    font-family: var(--font-mono);
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: var(--ink-mute);
    font-weight: 500;
    margin: 0 0 0.625rem;
  }
  .section-lede {
    color: var(--ink-mute);
    font-size: 0.9375rem;
    margin: 0 0 1.5rem;
    max-width: 64ch;
  }

  .cat {
    padding-block: clamp(2rem, 5vw, 3rem);
    border-bottom: 1px solid var(--rule);
  }
  .cat-ledger {
    margin-top: 2rem;
  }
  .cat-ledger-h {
    font-family: var(--font-display);
    font-weight: 500;
    font-variation-settings: 'opsz' 60, 'SOFT' 50;
    font-size: clamp(1.375rem, 2.5vw, 1.75rem);
    color: var(--ink);
    margin: 0 0 0.875rem;
    line-height: 1.1;
    letter-spacing: -0.005em;
    display: flex;
    align-items: baseline;
    gap: 0.625rem;
  }
  .cat-ledger-num {
    font-size: 12px;
    color: var(--ink-mute);
    font-weight: 500;
    letter-spacing: 0.12em;
  }
  .cat-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.625rem 2rem;
  }
  @media (min-width: 760px) {
    .cat-list {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  .cat-list li {
    padding-block: 0.25rem;
  }
  .cat-name {
    font-weight: 600;
    font-size: 16px;
  }
  .cat-status {
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--ink-mute);
  }
  .cat-brief {
    margin: 0.125rem 0 0;
    color: var(--ink-mute);
    font-size: 13px;
    line-height: 1.45;
  }

  .note {
    padding-block: clamp(2rem, 5vw, 3rem) 2rem;
  }
  .note-prose p {
    color: var(--ink);
    line-height: 1.7;
    margin: 0 0 1rem;
    max-width: 64ch;
  }
  .note-prose a {
    color: var(--accent);
    text-decoration: underline;
    text-decoration-color: color-mix(in oklab, var(--accent) 50%, transparent);
    text-underline-offset: 3px;
  }
  .note-prose a:hover {
    text-decoration-color: var(--accent);
  }
</style>
