---
import BaseLayout from '~/layouts/BaseLayout.astro'

const sections = [
  {
    slug: 'privacy',
    label: 'Privacy policy',
    desc: "What we collect, what we don't, your rights.",
  },
  { slug: 'terms', label: 'Terms of use', desc: 'The rules for using oriz finance.' },
  { slug: 'disclaimer', label: 'Disclaimer', desc: 'Includes the SEBI / IRDAI / RBI section.' },
  { slug: 'cookies', label: 'Cookie policy', desc: 'What cookies and localStorage we set.' },
  { slug: 'grievance', label: 'Grievance officer', desc: 'Mandatory contact under IT Rules 2021.' },
]
---

<BaseLayout
  title="Legal — oriz finance"
  description="Privacy, terms, and grievance contact for finance.oriz.in."
>
  <header class="prose-spine page-head">
    <p class="eyebrow"><a href="/">finance</a> / legal</p>
    <h1>Legal</h1>
  </header>

  <section class="prose-spine legal-section">
    <ul class="legal-list">
      {sections.map((s) => (
        <li>
          <a class="toc-row legal-row" href={`/legal/${s.slug}/`}>
            <span class="toc-name legal-name">{s.label}</span>
            <span class="toc-value legal-desc">{s.desc}</span>
          </a>
        </li>
      ))}
    </ul>
  </section>
</BaseLayout>

<style>
  .legal-section {
    padding-block: 2.5rem 5rem;
  }
  .legal-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }
  .legal-row {
    padding-block: 0.625rem;
    align-items: baseline;
  }
  .legal-name {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 1.25rem;
    color: var(--ink);
  }
  .legal-row:hover .legal-name {
    color: var(--accent);
  }
  .legal-desc {
    font-family: var(--font-sans);
    font-size: 0.875rem;
    color: var(--ink-mute);
  }
</style>
